# ============================================================
#  server/.env.example
#  Copy to server/.env and fill in real values. server/.env is
#  gitignored; this template is committed, so DO NOT put real
#  secrets here.
# ============================================================

# --- Server ---
PORT=4000
NODE_ENV=development

# Comma-separated origins allowed by CORS (Vite default is http://localhost:5173).
# In development, any localhost port is also allowed automatically.
CORS_ORIGIN=http://localhost:5173

# --- Storage: MongoDB Atlas (REQUIRED — server refuses to boot without this) ---
# Atlas dashboard -> Connect -> Drivers -> copy the SRV string.
# URL-encode the password if it has @ : / ? # & or other special chars.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=coldmail

# --- SMTP / Nodemailer (REQUIRED to actually send mail) ---
# Gmail: enable 2FA, then create an App Password at
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# "From" header on outgoing mail. Falls back to SMTP_USER if unset.
MAIL_FROM="Your Name <your@gmail.com>"

# --- AI providers (OPTIONAL — features hide themselves if no keys are set) ---
# Gemini: free API key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Default when the browser does not send X-AI-Model (fallback only).
GEMINI_MODEL=gemini-2.5-flash

# Groq: free API key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=groq/compound

# Default provider when the browser does not send X-AI-Provider: gemini | groq
AI_PROVIDER=gemini

# In the app header, use "Model: …" to pick provider + model — applies to all AI features.
ENRICH_CONFIDENCE_THRESHOLD=0.5

# --- Rate limiting ---
# Window in minutes, and max sends per window per IP
RATE_LIMIT_WINDOW_MIN=1
RATE_LIMIT_MAX=30

# Delay (ms) between sends inside a bulk request, to avoid SMTP throttling
BULK_SEND_DELAY_MS=250

# --- Resume Tailor (OPTIONAL — uses Gemini above) ---
# Default LaTeX resume folder relative to the project root (parent of server/).
# Must contain a main.tex.
CV_DEFAULT_PATH=./Sk_Sahil_Parvez_CV_
# Public LaTeX compile service. Override if you host your own.
TEXLIVE_NET_URL=https://texlive.net/cgi-bin/latexcgi
